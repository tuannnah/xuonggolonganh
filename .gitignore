.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# SQLite database (không commit dữ liệu thật)
*.db
*.db-journal
*.db-shm
*.db-wal

# Log files
*.log
error.log

# Backup folder (chỉ dùng local)
/backup_static_html/
